# Maya1 TTS server configuration.
# Copy to `.env` and adjust. All variables are optional; defaults shown.
#
#   cp .env.example .env
#
# Every variable maps to a field in src/maya1_server/config.py (MAYA1_ prefix).

# --- HTTP server ---
MAYA1_HOST=0.0.0.0
MAYA1_PORT=41217
MAYA1_LOG_LEVEL=INFO
# Comma-separated allowed origins, or * for all.
MAYA1_CORS_ALLOW_ORIGINS=*

# --- Model / codec ---
MAYA1_MODEL_REPO=maya-research/maya1
MAYA1_SNAC_REPO=hubertsiuzdak/snac_24khz

# --- Device / precision ---
# auto | cuda | cpu   (cpu is for smoke tests only - it is extremely slow)
MAYA1_DEVICE=auto
# bfloat16 | float16 | float32  (transformers backend only, see below)
MAYA1_DTYPE=bfloat16
# Run a tiny generation on startup so the first request is warm.
MAYA1_WARMUP=true

# --- Backend selection ---
# true  = quantized GGUF via llama.cpp (default) - much faster, far lower VRAM.
# false = original full-precision transformers backend (kept as an option).
MAYA1_USE_GGUF=true
MAYA1_GGUF_REPO=Mungert/maya1-GGUF
# Which quantization to download/load - just the short name. Valid values
# (smallest/fastest/lowest-quality -> largest/slowest/highest-quality), full
# details + links in docs/DEPLOYMENT.md §4a:
#   q2_k_s  q2_k_m  q3_k_s  q3_k_m  q4_0  q4_1  q4_k_s  q4_k_m (default)
#   q5_k_m  q6_k_m  q8_0  f16_q8_0
MAYA1_GGUF_QUANT=q4_k_m
# Advanced: exact filename override in MAYA1_GGUF_REPO, bypassing MAYA1_GGUF_QUANT
# entirely (e.g. to load a custom/third-party GGUF build). Leave unset normally.
# MAYA1_GGUF_FILENAME_OVERRIDE=maya1-q4_k_s.gguf
# Context window: must fit prompt + max_new_tokens with room to spare.
MAYA1_GGUF_N_CTX=8192
# -1 = offload all layers to GPU. Set to 0 to force CPU-only GGUF inference.
MAYA1_GGUF_N_GPU_LAYERS=-1
# Leave unset to let llama.cpp pick a thread count automatically.
# MAYA1_GGUF_N_THREADS=8

# --- Default generation parameters (Maya1 model-card recommendations) ---
# Ceiling for generated tokens. Requests that omit max_new_tokens get an
# auto-estimated budget (see docs/API.md#automatic-length-max_new_tokens),
# clamped to this value.
MAYA1_MAX_NEW_TOKENS=2048
MAYA1_MIN_NEW_TOKENS=28
MAYA1_TEMPERATURE=0.4
MAYA1_TOP_P=0.9
MAYA1_REPETITION_PENALTY=1.1

# --- Automatic max_new_tokens estimation ---
# Assumed speaking rate (chars/sec) used to estimate a safe token budget from
# input length when a request omits max_new_tokens. Lower = more generous.
MAYA1_AUTO_TOKENS_CHARS_PER_SECOND=12.0
# Safety multiplier applied on top of the raw estimate.
MAYA1_AUTO_TOKENS_HEADROOM=1.6
# Minimum estimated budget, even for very short input.
MAYA1_AUTO_TOKENS_FLOOR=256

# --- Guardrails ---
MAYA1_MAX_INPUT_CHARS=2000
MAYA1_WARN_UNKNOWN_TAGS=true

# Default voice used when a request supplies no description.
MAYA1_DEFAULT_DESCRIPTION=Realistic male voice in the 30s age with american accent. Normal pitch, warm timbre, conversational pacing.

# --- Optional: gated/private model access ---
# Only needed if you point MAYA1_MODEL_REPO at a private HuggingFace repo.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
