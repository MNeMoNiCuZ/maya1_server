# Keep the build context small and secrets out of the image.
.git
.gitignore
.env
*.env
!/.env.example

venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Local docs build artefacts / audio samples
*.wav
*.log
tmp/
temp/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# The Windows venv helper batch files are host-only.
*.bat
